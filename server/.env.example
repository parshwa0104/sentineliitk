# MongoDB Atlas URI — replace with your own
MONGO_URI=mongodb://localhost:27017/sentinel

# Allowed frontend origin(s), comma-separated
CLIENT_ORIGIN=http://localhost:3000

# Primary AI provider: groq | anthropic | gemini (leave blank for auto-detect)
AI_PROVIDER=gemini

# Gemini API Key — replace with your own
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Groq API key and model (recommended for low-cost real-time chat)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic API Key — replace with your own
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
